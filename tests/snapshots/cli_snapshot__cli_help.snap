Semantic grep that stays local

Usage: ig [OPTIONS] [QUERY] [PATH]

Arguments:
  [QUERY]  
  [PATH]   

Options:
      --add [<PATH>]        
      --rm [<PATH>]         
      --status              
      --daemon              
      --mcp                 
  -f, --force               
      --regex               
      --json                
  -C, --context <CONTEXT>   [default: 2]
      --type <TYPE_FILTER>  
      --include <GLOBS>     
      --exclude <GLOBS>     
  -n, --limit <LIMIT>       
      --no-watch            
      --first-line-only     
      --file-name-only      
      --verbose             
  -h, --help                Print help
  -V, --version             Print version
