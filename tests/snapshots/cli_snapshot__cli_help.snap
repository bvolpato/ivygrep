Semantic grep that stays local

Usage: ivygrep [OPTIONS] [QUERY] [PATH]

Arguments:
  [QUERY]  
  [PATH]   

Options:
      --index [<PATH>]      
      --add [<PATH>]        
      --rm [<PATH>]         
      --status              
      --daemon              
  -f, --force               
      --regex               
      --json                
  -C, --context <CONTEXT>   [default: 0]
      --type <TYPE_FILTER>  
  -n, --limit <LIMIT>       
      --no-watch            
      --first-line-only     
      --file-name-only      
  -h, --help                Print help
  -V, --version             Print version
