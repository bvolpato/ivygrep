source: tests/cli_snapshot.rs
expression: text
---
Semantic grep that stays local

Usage: ig [OPTIONS] [QUERY] [PATH]

Arguments:
  [QUERY]  
  [PATH]   

Options:
      --add [<PATH>]          
      --rm [<PATH>]           
      --status                
      --daemon                
      --mcp                   
      --wait-for-enhancement  
  -f, --force                 
  -l, --literal               Fast exact-match search backed by the index. Deterministic results, orders of magnitude faster than grep/rg for indexed repos
      --json                  
  -C, --context <CONTEXT>     [default: 2]
      --type <TYPE_FILTER>    
      --all-indices           
      --include <GLOBS>       
      --exclude <GLOBS>       
  -n, --limit <LIMIT>         
      --no-limit              
      --no-watch              
      --first-line-only       
      --file-name-only        
      --verbose               
      --skip-gitignore        
      --hash                  Use lightweight hash-based embeddings instead of the default ONNX neural model. Faster startup, no model download, lower quality
  -h, --help                  Print help
  -V, --version               Print version
